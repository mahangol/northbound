# Copy this file to .env.local and fill in real values.
# .env.local is gitignored by default — never commit real secrets.

# Example: if you wire up the lead form to an email service (see README §6)
# RESEND_API_KEY=

# Example: if you wire up the lead form to a CRM
# HUBSPOT_API_KEY=

# Example: if you add a database for storing leads
# DATABASE_URL=
